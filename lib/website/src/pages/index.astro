---
import NewsletterForm from "@components/Newsletter.astro";
import { SectionHeaderStandard } from "@walle/components";
import { BlogPostsLayout } from "@walle/layouts";
---

<BlogPostsLayout headerTitle="Home" clickableCard={true}>
  <SectionHeaderStandard
    title="Fabrizio Cafolla"
    subtitle="DevOps & Cloud Engineer @ SparkFabrik"
    variant="secondary"
  >
    <div>
      <h5>
        Founder of <a href="https://italiaopensource.com">Italia Open-Source</a> and Community Manager
        of <a href="https://www.latinaintech.org/it">Latina in Tech</a>.
      </h5>
    </div>
  </SectionHeaderStandard>
  <div slot="after" class="newsletter-section">
    <NewsletterForm showDescription={false} type="white" />
  </div>
</BlogPostsLayout>

<style>
  .newsletter-section {
    border-radius: 8px;
    margin-top: 2rem;
    display: flex;
    justify-content: center;
  }
</style>
