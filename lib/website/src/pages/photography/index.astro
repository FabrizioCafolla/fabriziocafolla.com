---
import { BaseLayout } from "@walle/layouts";
import { SectionHeaderStandard } from "@walle/components";
import PhotoCard from "../../components/photography/PhotoCard.astro";
import { getCollection } from "astro:content";

const photosCollection = await getCollection("photos");

interface Photo {
  title: string;
  description: string;
  location: string;
  date: string;
  path: string;
}

const photos: Photo[] = photosCollection.flatMap((entry) => entry.data.photos);
---

<BaseLayout headerTitle="Photography">
  <div class="photography">
    <SectionHeaderStandard
      title="Photography"
      subtitle="Moments, places, silence"
      variant="secondary"
    />

    <div class="photography__masonry">
      {
        photos.map((photo) => (
          <PhotoCard
            title={photo.title}
            description={photo.description}
            location={photo.location}
            date={photo.date}
            path={photo.path}
          />
        ))
      }
    </div>
  </div>

  <dialog class="photo-modal" id="photo-modal" aria-label="Photo viewer">
    <button class="photo-modal__close" type="button" aria-label="Close">&times;</button>
    <img class="photo-modal__img" src="" alt="" />
  </dialog>
</BaseLayout>

<style>
  .photography {
    width: 100%;
    min-height: 60vh;
  }

  .photography__masonry {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 32px 64px;
    columns: 3;
    column-gap: 16px;
  }

  @media (max-width: 1024px) {
    .photography__masonry {
      columns: 2;
      padding: 0 24px 48px;
    }
  }

  @media (max-width: 640px) {
    .photography__masonry {
      columns: 1;
      padding: 0 16px 40px;
    }
  }

  .photo-modal {
    border: none;
    background: transparent;
    padding: 0;
    max-width: 92vw;
    max-height: 92vh;
    overflow: visible;
  }

  .photo-modal::backdrop {
    background: rgba(0, 0, 0, 0.88);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .photo-modal[open] {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .photo-modal__img {
    display: block;
    max-width: 92vw;
    max-height: 92vh;
    width: auto;
    height: auto;
    object-fit: contain;
    border-radius: 4px;
  }

  .photo-modal__close {
    position: fixed;
    top: 20px;
    right: 24px;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.12);
    color: #fff;
    border: none;
    border-radius: 50%;
    font-size: 1.6rem;
    line-height: 1;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .photo-modal__close:hover {
    background: rgba(255, 255, 255, 0.25);
  }
</style>

<script>
  function initPhotoZoom() {
    const modal = document.getElementById("photo-modal") as HTMLDialogElement | null;
    if (!modal || !("showModal" in modal)) return;

    const modalImg = modal.querySelector<HTMLImageElement>(".photo-modal__img");
    const closeBtn = modal.querySelector<HTMLButtonElement>(".photo-modal__close");
    if (!modalImg) return;

    // Zoom is a desktop-only affordance: skip on touch / coarse-pointer devices.
    const canZoom = window.matchMedia("(hover: hover) and (pointer: fine)").matches;

    if (canZoom) {
      document.querySelectorAll<HTMLElement>(".photo-card").forEach((card) => {
        const img = card.querySelector<HTMLImageElement>("img");
        if (!img) return;
        card.addEventListener("click", () => {
          modalImg.src = img.currentSrc || img.src;
          modalImg.alt = img.alt;
          modal.showModal();
        });
      });
    }

    closeBtn?.addEventListener("click", () => modal.close());
    modal.addEventListener("click", (event) => {
      if (event.target === modal) modal.close();
    });
  }

  document.addEventListener("DOMContentLoaded", initPhotoZoom);
  document.addEventListener("astro:page-load", initPhotoZoom);
</script>
