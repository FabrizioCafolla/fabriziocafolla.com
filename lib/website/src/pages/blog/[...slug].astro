---
import { type CollectionEntry, getCollection } from "astro:content";
import { render } from "astro:content";
import { BlogPostLayout } from "@walle/layouts";
import { calculateReadingTime } from "@utils";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  const sorted = [...posts].sort((a, b) => {
    const aDate = a.data.publishDate?.getTime() ?? 0;
    const bDate = b.data.publishDate?.getTime() ?? 0;
    return aDate - bDate;
  });

  return sorted.map((post, index) => {
    const prev = index > 0 ? sorted[index - 1] : undefined;
    const next = index < sorted.length - 1 ? sorted[index + 1] : undefined;
    return {
      params: { slug: post.id },
      props: {
        post,
        prevPost: prev ? { title: prev.data.title, slug: `/blog/${prev.id}` } : undefined,
        nextPost: next ? { title: next.data.title, slug: `/blog/${next.id}` } : undefined,
      },
    };
  });
}

interface Props {
  post: CollectionEntry<"posts">;
  prevPost?: { title: string; slug: string };
  nextPost?: { title: string; slug: string };
}

const { post, prevPost, nextPost } = Astro.props;

const { Content } = await render(post);

const data = {
  readingTime: calculateReadingTime(post.body || "").text,
  ...post.data,
  prevPost,
  nextPost,
};
---

<BlogPostLayout {...data}>
  <Content />
</BlogPostLayout>
