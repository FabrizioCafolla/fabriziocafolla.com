---
import { BaseLayout } from "@walle/layouts";
import { SectionHeaderStandard } from "@walle/components";
import { getCollection } from "astro:content";
import GuideSection from "@components/guides/GuideSection.astro";
import GuideMap from "@components/guides/GuideMap.astro";

export async function getStaticPaths() {
  const guides = await getCollection("guides");

  const paths = guides.flatMap((guide) => {
    const mainPath = { params: { slug: guide.data.slug }, props: { guide } };
    const aliasPaths = (guide.data.aliases || []).map((alias: string) => ({
      params: { slug: alias },
      props: { guide },
    }));
    return [mainPath, ...aliasPaths];
  });

  return paths;
}

interface Place {
  name: string;
  cost?: string;
  maps?: string;
  notes?: string;
  hours?: string[];
  type: string[];
  rating: string;
}

const { guide } = Astro.props;
const { title, description, tips, places } = guide.data;

// Group places by primary type (type[0])
const grouped = places.reduce(
  (acc: Record<string, Place[]>, place: Place) => {
    const key = place.type[0] || "Other";
    if (!acc[key]) acc[key] = [];
    acc[key].push(place);
    return acc;
  },
  {} as Record<string, Place[]>
);

// Sort sections by frequency (most places first)
const sections = Object.entries(grouped)
  .sort(([, a], [, b]) => (b as Place[]).length - (a as Place[]).length)
  .map(([type, places]) => ({
    type,
    slug: type
      .toLowerCase()
      .replace(/\s+/g, "-")
      .replace(/[^a-z0-9-]/g, ""),
    places: places as Place[],
  }));

// Parse tips markdown into HTML
function parseTips(md: string): string {
  return md
    .split("\n")
    .filter((line) => line.trim())
    .map((line) => {
      const content = line.replace(/^-\s*/, "").replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>");
      return `<li>${content}</li>`;
    })
    .join("\n");
}

const tipsHtml = tips ? parseTips(tips) : null;
---

<BaseLayout headerTitle={title}>
  <div class="guide-page">
    <SectionHeaderStandard
      title={title}
      subtitle={`${places.length} places · ${sections.length} sections`}
      variant="secondary"
    />

    {
      description && (
        <div class="guide-page__description-wrapper">
          <p class="guide-page__description">{description}</p>
        </div>
      )
    }

    <div class="guide-page__container">
      <GuideMap places={places} />

      <nav class="guide-nav" aria-label="Guide sections">
        {
          sections.map(({ type, places }) => (
            <button class="guide-nav__item" data-type={type}>
              <span class="guide-nav__label">{type}</span>
              <span class="guide-nav__count">{places.length}</span>
            </button>
          ))
        }
        {
          tipsHtml && (
            <button class="guide-nav__item guide-nav__item--tips" data-type="tips">
              <span class="guide-nav__label">Tips</span>
            </button>
          )
        }
        <button class="guide-nav__reset" id="guide-filter-reset" aria-label="Reset filters">
          <span>×</span>
          <span>Reset</span>
        </button>
      </nav>

      {
        sections.map(({ type, slug, places }) => (
          <GuideSection id={slug} title={type} places={places} />
        ))
      }

      {
        tipsHtml && (
          <section class="guide-tips" id="tips">
            <h2 class="guide-tips__title">Tips</h2>
            <ul class="guide-tips__list" set:html={tipsHtml} />
          </section>
        )
      }
    </div>
  </div>
</BaseLayout>

<style>
  .guide-page {
    width: 100%;
    min-height: 80vh;
  }

  .guide-page__description-wrapper {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 32px;
  }

  .guide-page__description {
    font-size: 15px;
    line-height: 1.6;
    color: var(--gray-dark);
    margin: 0 0 32px 0;
    white-space: pre-line;
  }

  .guide-page__container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 32px 64px;
  }

  /* Navigation */
  .guide-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 10px;
    padding: 0 0 40px;
    margin-bottom: 40px;
    position: relative;
  }

  .guide-nav::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 50%;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--gray-medium), transparent);
  }

  .guide-nav__item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 14px;
    border: 1px solid var(--gray);
    border-radius: 100px;
    background: transparent;
    color: var(--gray-darker);
    font-family: inherit;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    white-space: nowrap;
  }

  .guide-nav__item:hover {
    border-color: var(--primary);
    color: var(--primary);
    background: rgba(13, 31, 60, 0.04);
  }

  .guide-nav__item.active {
    background: var(--primary);
    border-color: var(--primary);
    color: var(--white);
  }

  .guide-nav__item.active:hover {
    background: var(--primary-light);
    border-color: var(--primary-light);
    color: var(--white);
  }

  .guide-nav__item--tips {
    border-color: var(--gray-medium);
  }

  .guide-nav__reset {
    display: none;
    align-items: center;
    gap: 5px;
    padding: 8px 14px;
    border-radius: 100px;
    border: 1.5px solid var(--primary);
    background: transparent;
    color: var(--primary);
    font-family: inherit;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    white-space: nowrap;
  }

  .guide-nav__reset.visible {
    display: inline-flex;
  }

  .guide-nav__reset:hover {
    background: var(--primary);
    color: var(--white);
  }

  .guide-nav__count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 20px;
    height: 20px;
    padding: 0 6px;
    border-radius: 10px;
    background: var(--gray-light);
    font-size: 11px;
    font-weight: 700;
    color: var(--gray-dark);
    transition: all 0.2s ease;
  }

  .guide-nav__item.active .guide-nav__count {
    background: rgba(255, 255, 255, 0.2);
    color: var(--white);
  }

  .guide-nav__item:hover .guide-nav__count {
    background: rgba(13, 31, 60, 0.08);
    color: var(--primary);
  }

  /* Tips section */
  .guide-tips {
    margin-top: 48px;
    padding: 0;
  }

  .guide-tips__title {
    font-size: 20px;
    font-weight: 400;
    color: var(--black);
    margin: 0 0 24px 0;
  }

  .guide-tips__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
    max-width: 720px;
  }

  .guide-tips__list :global(li) {
    font-size: 15px;
    line-height: 1.75;
    color: var(--gray-darker);
    padding-left: 20px;
    position: relative;
  }

  .guide-tips__list :global(li)::before {
    content: "";
    position: absolute;
    left: 0;
    top: 11px;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--primary);
    opacity: 0.5;
  }

  .guide-tips__list :global(strong) {
    color: var(--black);
    font-weight: 600;
  }

  /* Responsive - smartphones */
  @media (max-width: 640px) {
    .guide-page__description-wrapper {
      padding: 0 16px;
    }

    .guide-page__container {
      padding: 0 16px 40px;
    }

    .guide-nav {
      gap: 8px;
      padding-bottom: 24px;
      margin-bottom: 24px;
    }

    .guide-nav__item {
      padding: 6px 12px;
      font-size: 12px;
    }

    .guide-tips {
      margin-top: 32px;
    }

    .guide-tips__title {
      font-size: 18px;
    }
  }

  /* Tablet portrait */
  @media (min-width: 641px) and (max-width: 768px) {
    .guide-page__description-wrapper {
      padding: 0 24px;
    }

    .guide-page__container {
      padding: 0 24px 48px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .guide-nav__item,
    .guide-nav__reset {
      transition: none;
    }
  }
</style>

<script>
  const navItems = document.querySelectorAll<HTMLButtonElement>(".guide-nav__item");
  const resetBtn = document.getElementById("guide-filter-reset");
  const activeTypes = new Set<string>();

  navItems.forEach((btn) => {
    btn.addEventListener("click", () => {
      const type = btn.dataset.type;
      if (!type) return;

      if (activeTypes.has(type)) {
        activeTypes.delete(type);
        btn.classList.remove("active");
      } else {
        activeTypes.add(type);
        btn.classList.add("active");
      }

      applyFilter();
    });
  });

  resetBtn?.addEventListener("click", () => {
    activeTypes.clear();
    navItems.forEach((btn) => btn.classList.remove("active"));
    applyFilter();
  });

  function applyFilter() {
    const hasFilter = activeTypes.size > 0;

    // Reset button visibility
    resetBtn?.classList.toggle("visible", hasFilter);

    // Show/hide guide sections
    document.querySelectorAll<HTMLElement>(".guide-section").forEach((section) => {
      const type = section.dataset.type ?? "";
      section.style.display = !hasFilter || activeTypes.has(type) ? "" : "none";
    });

    // Show/hide tips section
    const tips = document.querySelector<HTMLElement>(".guide-tips");
    if (tips) {
      tips.style.display = !hasFilter || activeTypes.has("tips") ? "" : "none";
    }

    // Hide map when only "tips" is selected (no location-based types active)
    const locationTypes = [...activeTypes].filter((t) => t !== "tips");
    const mapWrap = document.querySelector<HTMLElement>(".guide-map-wrap");
    if (mapWrap) {
      const showMap = !hasFilter || locationTypes.length > 0;
      const wasHidden = mapWrap.style.display === "none";
      mapWrap.style.display = showMap ? "" : "none";
      if (showMap && wasHidden) {
        document.dispatchEvent(new CustomEvent("guide-map-visible"));
      }
    }

    // Notify map (only with location types)
    document.dispatchEvent(
      new CustomEvent("guide-filter", {
        detail: { types: locationTypes },
      })
    );
  }
</script>
