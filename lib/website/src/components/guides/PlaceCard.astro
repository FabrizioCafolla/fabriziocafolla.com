---
interface Props {
  name: string;
  cost: string;
  maps?: string;
  notes?: string;
  hours?: string[];
  type: string[];
  rating: string;
}

const { name, cost, maps, notes, hours, type, rating } = Astro.props;

const ratingColors: Record<string, { bg: string; text: string }> = {
  consigliatissimo: { bg: "#dcfce7", text: "#166534" },
  consigliato: { bg: "#e0f2fe", text: "#075985" },
  caratteristico: { bg: "#fef3c7", text: "#92400e" },
  ok: { bg: "#f1f5f9", text: "#475569" },
};

const costLabels: Record<string, string> = {
  basso: "€",
  "medio-basso": "€€",
  medio: "€€",
  "medio-alto": "€€€",
  alto: "€€€€",
};

const ratingStyle = ratingColors[rating] || ratingColors.ok;
---

<div class="place-card">
  <div class="place-card__header">
    <h4 class="place-card__name">
      {
        maps ? (
          <a href={maps} target="_blank" rel="noopener noreferrer">
            {name}
          </a>
        ) : (
          name
        )
      }
    </h4>
    <div class="place-card__meta">
      <span class="place-card__cost">{costLabels[cost] || cost}</span>
      <span
        class="place-card__rating"
        style={`background: ${ratingStyle.bg}; color: ${ratingStyle.text};`}
      >
        {rating}
      </span>
    </div>
  </div>

  {notes && <p class="place-card__notes">{notes}</p>}

  <div class="place-card__footer">
    {
      hours && hours.length > 0 && (
        <div class="place-card__hours">
          {hours.map((h) => (
            <span class="place-card__hour-tag">{h}</span>
          ))}
        </div>
      )
    }
    {
      type.length > 1 && (
        <div class="place-card__types">
          {type.map((t) => (
            <span class="place-card__type-tag">{t}</span>
          ))}
        </div>
      )
    }
  </div>
</div>

<style>
  .place-card {
    padding: 1rem 1.25rem;
    border: 1px solid var(--color-border, #e2e8f0);
    border-radius: 0.5rem;
    transition: box-shadow 0.2s;
  }

  .place-card:hover {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }

  .place-card__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .place-card__name {
    font-size: 1.05rem;
    font-weight: 600;
    margin: 0;
  }

  .place-card__name a {
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid var(--color-primary, #0284c7);
  }

  .place-card__name a:hover {
    color: var(--color-primary, #0284c7);
  }

  .place-card__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .place-card__cost {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-muted, #64748b);
  }

  .place-card__rating {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.2rem 0.5rem;
    border-radius: 1rem;
    text-transform: capitalize;
  }

  .place-card__notes {
    font-size: 0.85rem;
    color: var(--color-text-muted, #64748b);
    margin: 0.5rem 0 0;
    line-height: 1.4;
  }

  .place-card__footer {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.6rem;
  }

  .place-card__hours,
  .place-card__types {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }

  .place-card__hour-tag {
    font-size: 0.7rem;
    padding: 0.15rem 0.4rem;
    background: var(--color-bg-subtle, #f8fafc);
    border: 1px solid var(--color-border, #e2e8f0);
    border-radius: 0.25rem;
    color: var(--color-text-muted, #64748b);
  }

  .place-card__type-tag {
    font-size: 0.7rem;
    padding: 0.15rem 0.4rem;
    background: var(--color-primary-light, #e0f2fe);
    border-radius: 0.25rem;
    color: var(--color-primary, #0284c7);
  }
</style>
