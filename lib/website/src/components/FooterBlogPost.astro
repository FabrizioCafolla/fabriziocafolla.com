---
import { Icon } from "astro-icon/components";

export interface ReferralLink {
  name: string;
  description: string;
  link?: string;
  code?: string;
  reward: string;
}

export interface Props {
  referralLinks?: ReferralLink[];
}

const defaultReferralLinks: ReferralLink[] = [
  {
    name: "Revolut",
    description: "Digital banking made simple",
    link: "https://revolut.com/referral/?referral-code=fabrizkc6s!JUL1-25-AR-L1&geo-redirect",
    reward: "Free card",
  },
  {
    name: "Airalo eSIM",
    description: "Stay connected while traveling",
    code: "FABRIZ2683",
    reward: "3$",
  },
  {
    name: "TheFork",
    description: "Discover and book restaurants",
    code: "7DA38543",
    reward: "€10",
  },
  {
    name: "Trade Republic",
    description: "Invest, spend, and save smartly",
    link: "https://refnocode.trade.re/q4rvc8f8",
    code: "q4rvc8f8",
    reward: "10$",
  },
];

const { referralLinks = defaultReferralLinks } = Astro.props;
---

<section class="referrals" aria-label="Referral links">
  <p class="referrals__label">Referral Links</p>
  <ul class="referrals__list">
    {
      referralLinks.map((referral) => (
        <li class="referral-item">
          <div class="referral-item__left">
            <span class="referral-item__name">{referral.name}</span>
            <span class="referral-item__desc">{referral.description}</span>
          </div>
          <div class="referral-item__right">
            <span class="referral-item__reward">{referral.reward}</span>
            {referral.code && (
              <div class="referral-item__code-wrap">
                <code class="referral-item__code">{referral.code}</code>
                <button
                  class="referral-item__copy"
                  data-code={referral.code}
                  aria-label={`Copy code ${referral.code}`}
                >
                  <Icon name="fa:copy" />
                </button>
              </div>
            )}
            {referral.link && (
              <a
                href={referral.link}
                target="_blank"
                rel="noopener noreferrer"
                class="referral-item__link"
                aria-label={`Open ${referral.name}`}
              >
                <Icon name="fa:external-link" />
              </a>
            )}
          </div>
        </li>
      ))
    }
  </ul>
</section>

<style>
  .referrals {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--gray);
  }

  .referrals__label {
    font-size: 0.75rem;
    color: var(--gray-dark);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 0.875rem;
  }

  .referrals__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .referral-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.625rem 0;
    border-bottom: 1px solid var(--gray);
  }

  .referral-item:last-child {
    border-bottom: none;
  }

  .referral-item__left {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    min-width: 0;
  }

  .referral-item__name {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--primary-dark);
    white-space: nowrap;
  }

  .referral-item__desc {
    font-size: 0.8rem;
    color: var(--gray-dark);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .referral-item__right {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .referral-item__reward {
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--white);
    background: var(--secondary);
    padding: 0.15rem 0.5rem;
    border-radius: 3px;
  }

  .referral-item__code-wrap {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .referral-item__code {
    font-family: "NectoMono", monospace;
    font-size: 0.75rem;
    color: var(--primary-dark);
    background: var(--gray);
    padding: 0.15rem 0.4rem;
    border-radius: 3px;
  }

  .referral-item__copy {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: 1px solid var(--gray-medium);
    color: var(--gray-dark);
    cursor: pointer;
    padding: 0.25rem;
    border-radius: 3px;
    transition: all 0.15s ease;
    line-height: 1;
  }

  .referral-item__copy:hover {
    border-color: var(--primary);
    color: var(--primary);
  }

  .referral-item__copy :global(svg) {
    width: 11px;
    height: 11px;
  }

  .referral-item__copy.copied {
    border-color: var(--primary);
    color: var(--primary);
  }

  .referral-item__link {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--gray-dark);
    transition: color 0.15s ease;
    padding: 0.25rem;
  }

  .referral-item__link:hover {
    color: var(--primary);
  }

  .referral-item__link :global(svg) {
    width: 12px;
    height: 12px;
  }

  @media (max-width: 480px) {
    .referral-item__desc {
      display: none;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>(".referral-item__copy").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const code = btn.dataset.code;
      if (!code) return;
      try {
        await navigator.clipboard.writeText(code);
      } catch {
        const ta = document.createElement("textarea");
        ta.value = code;
        ta.style.cssText = "position:fixed;left:-9999px";
        document.body.appendChild(ta);
        ta.select();
        document.execCommand("copy");
        ta.remove();
      }
      btn.classList.add("copied");
      setTimeout(() => btn.classList.remove("copied"), 2000);
    });
  });
</script>
